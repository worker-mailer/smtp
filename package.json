{
  "name": "@workermailer/smtp",
  "version": "0.1.4",
  "description": "SMTP client for Cloudflare Workers with queue support and email utilities.",
  "packageManager": "bun@1.3.14",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "import": "./dist/queue.mjs",
      "require": "./dist/queue.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cloudflare",
    "workers",
    "cloudflare-workers",
    "email",
    "smtp"
  ],
  "author": "André Ribas (@RibasSu)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/worker-mailer/smtp.git"
  },
  "license": "MIT",
  "homepage": "https://workermailer.com",
  "marketplace": {
    "pluginId": "@workermailer/smtp"
  },
  "plugin": {
    "id": "@workermailer/smtp",
    "capabilities": [
      "smtp.send",
      "email.compose",
      "queue.enqueue"
    ],
    "permissions": [
      "network.smtp",
      "queue"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p test/tsconfig.json --noEmit && tsc -p emdash-plugin/tsconfig.json --noEmit",
    "format": "prettier '**/*.{json,ts,js,cjs,mjs,md}' --write --ignore-path .gitignore"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260719.1",
    "@types/libqp": "^1.1.3",
    "@types/node": "^26.1.1",
    "emdash": "^0.29.0",
    "letterparser": "^0.1.8",
    "libqp": "^2.1.1",
    "prettier": "^3.9.5",
    "tsdown": "^0.22.11",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
