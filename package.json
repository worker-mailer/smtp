{
  "name": "@workermailer/smtp",
  "version": "0.1.1",
  "description": "SMTP client for Cloudflare Workers with queue support and email utilities.",
  "packageManager": "bun@1.3.11",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "import": "./dist/queue.mjs",
      "require": "./dist/queue.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cloudflare",
    "workers",
    "cloudflare-workers",
    "email",
    "smtp"
  ],
  "author": "André Ribas (@RibasSu)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RibasSu/worker-mailer.git"
  },
  "license": "MIT",
  "homepage": "https://workermailer.com",
  "marketplace": {
    "pluginId": "@workermailer/smtp"
  },
  "plugin": {
    "id": "@workermailer/smtp",
    "capabilities": [
      "smtp.send",
      "email.compose",
      "queue.enqueue"
    ],
    "permissions": [
      "network.smtp",
      "queue"
    ]
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "format": "prettier '**/*.{json,ts,js,cjs,mjs,md}' --write --ignore-path .gitignore"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20260411.1",
    "@types/libqp": "^1.1.3",
    "@types/node": "^25.6.0",
    "letterparser": "^0.1.8",
    "libqp": "^2.1.1",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.81.1"
  }
}
